# Core QGIS Server endpoint. Typical value:
# https://gis.examplecounty.gov/qgisserver?
VITE_QGIS_BASE_URL=https://gis.examplecounty.gov/qgisserver

# QGIS project file path or project reference expected by your QGIS Server setup.
# Example: /srv/qgis/projects/tax_parcels.qgz
VITE_QGIS_PROJECT_NAME=/srv/qgis/projects/tax_parcels.qgz

# Unlabeled parcel boundary layer in the QGIS project
VITE_PARCEL_LAYER_NAME=tax_parcels

# Pre-labeled parcel layer in the QGIS project
VITE_PARCEL_LABEL_LAYER_NAME=tax_parcels_labels

# Optional external WMS overlay
VITE_EXTERNAL_WMS_URL=https://services.example.com/geoserver/wms
VITE_EXTERNAL_WMS_LAYER_NAME=zoning:districts

# QGIS print layout template name
VITE_PRINT_LAYOUT_NAME=Tax_11x17_Landscape

# Initial map display (lon,lat)
VITE_INITIAL_CENTER=-104.9903,39.7392
VITE_INITIAL_ZOOM=13

# Parcel field used by search + popup title
VITE_SEARCHABLE_PARCEL_FIELD=parcel_id

# Popup attributes
VITE_IDENTIFY_FIELDS=parcel_id,owner_name,site_address,land_use,acreage

# Optional OGC API Features / WFS-like search endpoint
# Example OGC API Features URL:
# https://gis.examplecounty.gov/ogc/collections/tax_parcels/items
VITE_SEARCH_ENDPOINT_URL=https://gis.examplecounty.gov/ogc/collections/tax_parcels/items

# Projection for map view
VITE_MAP_PROJECTION=EPSG:3857
