# Core QGIS Server endpoint. Example:
# https://gis.examplecounty.gov/qgisserver
VITE_QGIS_BASE_URL=https://gis.examplecounty.gov/qgisserver

# QGIS project file path or project reference used by the MAP parameter.
# Example: /srv/qgis/projects/county_parcels.qgz
VITE_QGIS_PROJECT_NAME=/srv/qgis/projects/county_parcels.qgz

# Primary county parcel layers published in the QGIS project.
VITE_PARCEL_LAYER_NAME=tax_parcels
VITE_PARCEL_LABEL_LAYER_NAME=tax_parcels_labels

# Optional external WMS overlay. Leave blank to disable the zoning layer toggle.
# Replace these with the actual county overlay service if you use one.
VITE_EXTERNAL_WMS_URL=https://services.example.com/geoserver/wms
VITE_EXTERNAL_WMS_LAYER_NAME=zoning:districts

# QGIS print layout name for the county parcel PDF output.
VITE_PRINT_LAYOUT_NAME=CountyParcel_11x17

# Initial map display (lon,lat) and zoom.
VITE_INITIAL_CENTER=-104.9903,39.7392
VITE_INITIAL_ZOOM=13

# Parcel field used for search filters and popup titles.
VITE_SEARCHABLE_PARCEL_FIELD=parcel_id

# Search provider options:
# mock, ogcApiFeatures, wfs
VITE_SEARCH_PROVIDER=ogcApiFeatures

# Search URL for OGC API Features or WFS.
# OGC example:
# https://gis.examplecounty.gov/ogc/collections/tax_parcels/items
# WFS example:
# https://gis.examplecounty.gov/qgisserver
VITE_SEARCH_URL=https://gis.examplecounty.gov/ogc/collections/tax_parcels/items

# WFS-only settings. Required when VITE_SEARCH_PROVIDER=wfs.
# Use the exact typename published by QGIS Server or GeoServer.
VITE_SEARCH_TYPENAME=public:tax_parcels
VITE_SEARCH_WFS_VERSION=2.0.0
VITE_SEARCH_WFS_OUTPUT_FORMAT=application/json
VITE_SEARCH_WFS_SRS_NAME=EPSG:3857

# Limit the number of search matches shown in the compact result list.
VITE_SEARCH_MAX_RESULTS=5

# Projection used by the OpenLayers map.
VITE_MAP_PROJECTION=EPSG:3857
